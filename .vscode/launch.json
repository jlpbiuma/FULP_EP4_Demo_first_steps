{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit App",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/streamlit",
            "args": [
                "run",
                "${workspaceFolder}/main.py",
                "--server.port",
                "8501",
                "--server.address",
                "localhost"
            ],
            "python": "${workspaceFolder}/.venv/bin/python",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
